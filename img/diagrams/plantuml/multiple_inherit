@startuml
scale 800 width

interface NPC {
  void sleep()
}

interface Animal {
  void hide()
} 

interface ImaginaryCreature {
  void heal(NPC c)
}

abstract class AbstractNPC {
  void sleep()
}

class Butterfly {
  void hide()
}


class Unicorn {
  void heal(NPC c)
}




NPC <|.. Animal : extends
NPC <|.. ImaginaryCreature : extends

NPC <--  AbstractNPC : implements
Animal <--  Unicorn : implements
Animal <--  Butterfly : implements
ImaginaryCreature <-- Unicorn : implements

AbstractNPC <|-- Unicorn : extends
AbstractNPC <|-- Butterfly : extends






@enduml
